# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running the server.
# The .env file is gitignored and must NEVER be committed to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI providers ──────────────────────────────────────────────────────────────
# OpenAI — create at https://platform.openai.com/api-keys
VITE_OPENAI_KEY=sk-proj-...

# Anthropic — create at https://console.anthropic.com/settings/api-keys
VITE_ANTHROPIC_KEY=sk-ant-...

# ── Apollo.io ──────────────────────────────────────────────────────────────────
# Master API key — create at https://developer.apollo.io/
VITE_APOLLO_KEY=...

# ── Outlook / Microsoft Graph ──────────────────────────────────────────────────
# Register an app at https://portal.azure.com/ → App registrations
OUTLOOK_CLIENT_ID=...
OUTLOOK_CLIENT_SECRET=...
# The Microsoft account that sends emails (must match the authenticated user)
OUTLOOK_USER=you@outlook.com

# ── Gmail / Google OAuth ───────────────────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
# Must match the redirect URI registered in Google Cloud Console
# Production: https://auto-outbound.rithiksingh.com/api/gmail/auth-callback
# Development: http://localhost:3334/callback
GMAIL_REDIRECT_URI=http://localhost:3334/callback

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string — Render/Supabase/local
DATABASE_URL=postgresql://user:password@host:5432/dbname
