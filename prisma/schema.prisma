// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String
  title     String?
  company   String
  domain    String?
  linkedin  String?
  state     String  @default("new") // new, emailed, replied
  source    String? // csv, apollo, manual, etc
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emails    Email[]
}

model Email {
  id             Int          @id @default(autoincrement())
  to             String
  subject        String
  body           String
  sentAt         DateTime?
  failedAt       DateTime?
  error          String?
  userId         String
  company        String?
  provider       String       @default("outlook")
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId      Int
  scheduledAt    DateTime     // when this email should be sent
  createdAt      DateTime     @default(now())
  // Tracking
  trackingId     String       @unique @default(uuid())
  openCount      Int          @default(0)
  clickCount     Int          @default(0)
  firstOpenedAt  DateTime?
  events         EmailEvent[]
  // Reply tracking — populated after send by the email worker
  gmailMessageId        String?   // Gmail API message id
  gmailThreadId         String?   // Gmail thread id (used to detect replies)
  outlookMessageId      String?   // Graph API message id
  outlookConversationId String?   // Graph API conversation id (used to detect replies)
  repliedAt             DateTime? // when a reply was detected

  @@index([userId])
  @@index([scheduledAt])
  @@index([sentAt])
  @@index([trackingId])
  @@index([gmailThreadId])
  @@index([outlookConversationId])
}

model EmailEvent {
  id          Int      @id @default(autoincrement())
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  emailId     Int
  type        String   // 'open' | 'click'
  linkUrl     String?  // original URL for click events
  ip          String?
  userAgent   String?
  occurredAt  DateTime @default(now())

  @@index([emailId])
  @@index([type])
}

model User {
  id            String   @id  // our internal userId (email-prefix + timestamp)
  clerkId       String?  @unique // Clerk user ID — set on first Clerk login
  email         String   @unique
  name          String?
  password      String   @default("")
  senderName    String?
  senderEmail   String?
  modelId       String   @default("gpt-4o-mini")
  campaignMode  String   @default("startup")
  emailProvider String   @default("gmail")
  resumeText    String?
  prompt        String?
  // OAuth tokens stored as JSON blobs — survive deploys, no filesystem dependency
  gmailTokens   Json?    // { clientId, accessToken, refreshToken, expiresAt }
  outlookTokens Json?    // { clientId, accessToken, refreshToken, expiresAt }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ImportedCompany {
  id          Int      @id @default(autoincrement())
  apolloOrgId String?
  name        String
  domain      String   @unique
  industry    String?
  size        String?
  location    String?
  status      String   @default("pending") // pending, validating, discovered, drafting, approved, sent
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ScheduledDiscovery {
  id        Int     @id @default(autoincrement())
  userId    String  @unique
  runTime   String  // "09:00" HH:MM format
  dailyQuota Int
  enabled   Boolean @default(true)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
