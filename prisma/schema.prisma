// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  name      String
  title     String?
  company   String
  domain    String?
  linkedin  String?
  state     String  @default("new") // new, emailed, replied
  source    String? // csv, apollo, manual, etc
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emails    Email[]
}

model Email {
  id          Int       @id @default(autoincrement())
  to          String
  subject     String
  body        String
  sentAt      DateTime?
  failedAt    DateTime?
  error       String?
  userId      String
  company     String?
  provider    String    @default("outlook")
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId   Int
  scheduledAt DateTime  // when this email should be sent
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([scheduledAt])
  @@index([sentAt])
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImportedCompany {
  id          Int      @id @default(autoincrement())
  apolloOrgId String?
  name        String
  domain      String   @unique
  industry    String?
  size        String?
  location    String?
  status      String   @default("pending") // pending, validating, discovered, drafting, approved, sent
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ScheduledDiscovery {
  id        Int     @id @default(autoincrement())
  userId    String  @unique
  runTime   String  // "09:00" HH:MM format
  dailyQuota Int
  enabled   Boolean @default(true)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
